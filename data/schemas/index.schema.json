{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "IndexKit Index Entry",
  "description": "Schema for URL-level metadata entries in the W3Schools research index",
  "type": "object",
  "required": ["url", "host", "content_type", "category", "topic", "discovered_from", "discovered_at"],
  "properties": {
    "url": {
      "type": "string",
      "format": "uri",
      "description": "The publicly accessible URL"
    },
    "host": {
      "type": "string",
      "description": "Hostname of the URL"
    },
    "content_type": {
      "type": "string",
      "enum": ["hub", "lesson", "reference", "exercise", "quiz", "tool"],
      "description": "Classification of the page type"
    },
    "category": {
      "type": "string",
      "description": "Top-level category (tutorials, references, exercises, quizzes, tools)"
    },
    "topic": {
      "type": "string",
      "description": "Subject area or technology"
    },
    "discovered_from": {
      "type": "string",
      "enum": ["manual", "import", "permissioned_fetch"],
      "description": "How this URL was discovered"
    },
    "discovered_at": {
      "type": "string",
      "format": "date",
      "description": "ISO 8601 date when the URL was cataloged"
    }
  },
  "additionalProperties": false
}
