{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "IndexKit Taxonomy",
  "description": "Schema for the content taxonomy used to classify W3Schools URLs",
  "type": "object",
  "required": ["name", "version", "categories", "content_types"],
  "properties": {
    "name": { "type": "string" },
    "version": { "type": "string" },
    "categories": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label", "description", "topics"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "description": { "type": "string" },
          "topics": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    },
    "content_types": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
